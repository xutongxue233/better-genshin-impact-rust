{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BetterGI Rust",
  "version": "0.1.0",
  "identifier": "com.bettergi.rust",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BetterGI Rust",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility"
  }
}
